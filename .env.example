# Proxies (comma-separated). Format: ip:port:user:pass or full URL
# PROXIES=1.2.3.4:9000:user:pass,5.6.7.8:9000:user:pass
PROXIES=

# Default proxy protocol (socks5, http, https)
PROXY_TYPE=socks5

# Delay between API requests (ms)
MIN_DELAY=1500
MAX_DELAY=3000

# Server port
PORT=3000

DEBUG=false
